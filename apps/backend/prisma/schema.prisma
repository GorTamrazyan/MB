generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  COMPANY
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  ONLINE
  INVOICE
  CASH
}

enum PriceType {
  FIXED
  HOURLY
  DAILY
  CUSTOM
}

enum AddressType {
  MAIN
  BRANCH
  BILLING
}

enum ItemType {
  SERVICE
  PACKAGE
}

enum ItemStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  DELIVERED
  CANCELLED
}

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  passwordHash         String
  role                 Role      @default(CLIENT)
  isVerified           Boolean   @default(false)
  isActive             Boolean   @default(true)
  verificationToken    String?
  refreshTokenHash     String?
  refreshTokenExpiresAt DateTime?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  profile       UserProfile?
  company       Company?
  orders        Order[]
  reviews       Review[]
  notifications Notification[]

  @@index([email])
  @@map("users")
}

model UserProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  firstName   String?  @db.VarChar(100)
  lastName    String?  @db.VarChar(100)
  phone       String?  @db.VarChar(20)
  avatarUrl   String?
  bio         String?  @db.VarChar(500)
  location    String?  @db.VarChar(200)
  preferences Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Company {
  id            String   @id @default(uuid())
  userId        String   @unique
  companyName   String   @db.VarChar(200)
  legalName     String   @db.VarChar(200)
  taxId         String?  @db.VarChar(50)
  description   String?  @db.Text
  logoUrl       String?
  website       String?
  isVerified    Boolean  @default(false)
  verifiedAt    DateTime?
  averageRating Decimal  @default(0) @db.Decimal(3, 2)
  totalReviews  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  addresses  CompanyAddress[]
  services   Service[]
  packages   Package[]
  orderItems OrderItem[]
  reviews    Review[]
  portfolio  PortfolioItem[]

  @@index([isVerified])
  @@index([averageRating])
  @@map("companies")
}

model CompanyAddress {
  id         String      @id @default(uuid())
  companyId  String
  type       AddressType @default(MAIN)
  country    String      @db.VarChar(100)
  city       String      @db.VarChar(100)
  street     String?     @db.VarChar(200)
  postalCode String?     @db.VarChar(20)
  latitude   Decimal?    @db.Decimal(10, 8)
  longitude  Decimal?    @db.Decimal(11, 8)
  isPrimary  Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("company_addresses")
}

model Category {
  id          String     @id @default(uuid())
  name        String     @db.VarChar(100)
  slug        String     @unique @db.VarChar(120)
  description String?    @db.VarChar(500)
  icon        String?    @db.VarChar(50)
  parentId    String?
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  parent   Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children Category[] @relation("CategoryChildren")
  services Service[]

  @@index([parentId])
  @@index([slug])
  @@map("categories")
}

model Service {
  id               String    @id @default(uuid())
  companyId        String
  categoryId       String
  title            String    @db.VarChar(200)
  slug             String    @unique @db.VarChar(220)
  description      String    @db.Text
  shortDescription String?   @db.VarChar(300)
  price            Decimal   @db.Decimal(12, 2)
  priceType        PriceType @default(FIXED)
  duration         String?   @db.VarChar(100)
  isActive         Boolean   @default(true)
  viewsCount       Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category        Category         @relation(fields: [categoryId], references: [id])
  images          ServiceImage[]
  packageServices PackageService[]

  @@index([companyId])
  @@index([categoryId])
  @@index([isActive])
  @@index([price])
  @@index([slug])
  @@map("services")
}

model ServiceImage {
  id        String   @id @default(uuid())
  serviceId String
  imageUrl  String
  altText   String?  @db.VarChar(200)
  order     Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("service_images")
}

model Package {
  id              String   @id @default(uuid())
  companyId       String
  name            String   @db.VarChar(200)
  slug            String   @unique @db.VarChar(220)
  description     String?  @db.Text
  totalPrice      Decimal  @db.Decimal(12, 2)
  discountPercent Decimal  @default(0) @db.Decimal(5, 2)
  finalPrice      Decimal  @db.Decimal(12, 2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company  Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  services PackageService[]

  @@index([companyId])
  @@map("packages")
}

model PackageService {
  id            String   @id @default(uuid())
  packageId     String
  serviceId     String
  quantity      Int      @default(1)
  priceOverride Decimal? @db.Decimal(12, 2)
  createdAt     DateTime @default(now())

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([packageId, serviceId])
  @@map("package_services")
}

model Order {
  id              String        @id @default(uuid())
  userId          String
  orderNumber     String        @unique
  totalAmount     Decimal       @db.Decimal(12, 2)
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(ONLINE)
  stripePaymentId String?
  stripeEventId   String?
  notes           String?       @db.VarChar(1000)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user    User        @relation(fields: [userId], references: [id])
  items   OrderItem[]
  reviews Review[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id         String     @id @default(uuid())
  orderId    String
  companyId  String
  itemType   ItemType
  itemId     String
  itemName   String     @db.VarChar(200)
  unitPrice  Decimal    @db.Decimal(12, 2)
  quantity   Int        @default(1)
  totalPrice Decimal    @db.Decimal(12, 2)
  itemStatus ItemStatus @default(PENDING)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id])

  @@index([orderId])
  @@index([companyId])
  @@map("order_items")
}

model Review {
  id         String   @id @default(uuid())
  companyId  String
  userId     String
  orderId    String?
  rating     Int
  title      String?  @db.VarChar(200)
  comment    String?  @db.Text
  isVerified Boolean  @default(false)
  isApproved Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
  order   Order?  @relation(fields: [orderId], references: [id])

  @@unique([orderId, userId, companyId])
  @@index([companyId])
  @@index([isApproved])
  @@map("reviews")
}

model PortfolioItem {
  id             String    @id @default(uuid())
  companyId      String
  title          String    @db.VarChar(200)
  description    String?   @db.Text
  imageUrl       String?
  projectUrl     String?
  clientName     String?   @db.VarChar(200)
  completionDate DateTime?
  tags           String[]
  order          Int       @default(0)
  isFeatured     Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("portfolio_items")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(200)
  message   String   @db.Text
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}
